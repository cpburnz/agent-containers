#!/usr/bin/env bash
#
# Run OpenCode from the current directory.
#
# Copy this to "/usr/local/bin/".
#
set -e

proj="$(basename "$(pwd)")"
name="open-code-${proj}"

# Determine engine.
if which podman 2>/dev/null; then
	engine=podman
	engine_args='--add-host=host.containers.internal:host-gateway --userns=keep-id:uid=1000,gid=1000'
else
	engine=docker
	engine_args=--add-host=host.docker.internal:host-gateway
fi

# Create mounted directories.
mkdir -p "$HOME/.config/opencode"
mkdir -p "$HOME/.local/share/opencode"
mkdir -p "$HOME/.local/state/opencode"

exec $engine run --rm --tty --interactive \
  --name "$name" \
  $engine_args \
  -v "$HOME/.config/opencode:/home/node/.config/opencode" \
  -v "$HOME/.local/share/opencode:/home/node/.local/share/opencode" \
  -v "$HOME/.local/state/opencode:/home/node/.local/state/opencode" \
  -v "$(pwd):/app" \
  open-code "$@"
