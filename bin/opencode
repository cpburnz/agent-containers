#!/usr/bin/env bash
#
# Run OpenCode from the current directory.
#
# Copy this to "/usr/local/bin/".
#
set -e

proj="$(basename "$(pwd)")"
name="agent-opencode-${proj}"

# Get XDG directories.
host_cache_home="${XDG_CACHE_HOME:-$HOME/.cache}"
host_config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
host_data_home="${XDG_DATA_HOME:-$HOME/.local/share}"
host_state_home="${XDG_STATE_HOME:-$HOME/.local/state}"

# Lookup proxy IP.
proxy_ip="$(podman container inspect agent-proxy | jq -er '.[0].NetworkSettings.Networks["agent-internal-net"].IPAddress')"
proxy="http://$proxy_ip:3128"
if [ -z "$proxy_ip" ]; then
	exit "Failed to get agent-proxy ip."
fi

# Create mounted directories.
mkdir -p "$host_cache_home/opencode"
mkdir -p "$host_config_home/opencode"
mkdir -p "$host_data_home/opencode"
mkdir -p "$host_state_home/opencode"

# Run OpenCode.
exec podman run --rm -it \
	--name "$name" \
	--net agent-internal-net \
	--userns=keep-id:uid=1000,gid=1000 \
	-e "HTTPS_PROXY=$proxy" \
	-e "HTTP_PROXY=$proxy" \
	-e NO_PROXY=localhost,127.0.0.1 \
	-v "$host_cache_home/opencode:/home/node/.cache/opencode" \
	-v "$host_config_home/opencode:/home/node/.config/opencode" \
	-v "$host_data_home/opencode:/home/node/.local/share/opencode" \
	-v "$host_state_home/opencode:/home/node/.local/state/opencode" \
	-v "$(pwd):/app" \
	localhost/agent-opencode "$@"
